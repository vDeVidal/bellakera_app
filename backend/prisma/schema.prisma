generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario         Int       @id @default(autoincrement())
  telefono           String    @unique @db.VarChar(15)
  pin_hash           String    @db.VarChar(255)
  nombre             String?   @db.VarChar(100)
  apellido           String?   @db.VarChar(100)
  foto_perfil_url    String?
  fecha_nacimiento   DateTime? @db.Date
  fecha_registro     DateTime  @default(now())
  ultimo_acceso      DateTime?
  estado             String    @default("pendiente") @db.VarChar(20) // pendiente, activo, suspendido
  verificado         Boolean   @default(false)
  codigo_verificacion String?  @db.VarChar(10)
  codigo_expira      DateTime?
  puntos_acumulados  Int       @default(0)

  redes_sociales     RedSocial[]
  ventas             Venta[]

  galeria            Galeria[]
  likes              LikeGaleria[]
  participaciones    Participacion[]

  @@map("usuarios")
}

model RedSocial {
  id_red      Int     @id @default(autoincrement())
  id_usuario  Int
  plataforma  String  @db.VarChar(50)
  username    String  @db.VarChar(100)
  url         String?

  usuario     Usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("redes_sociales")
}

model Administrador {
  id_admin        Int       @id @default(autoincrement())
  telefono        String    @unique @db.VarChar(15)
  pin_hash        String    @db.VarChar(255)
  nombre          String    @db.VarChar(100)
  apellido        String    @db.VarChar(100)
  rol             String    @db.VarChar(50)
  activo          Boolean   @default(true)
  fecha_creacion  DateTime  @default(now())

  eventos_creados Evento[]

  @@map("administradores")
}

model Evento {
  id_evento         Int       @id @default(autoincrement())
  nombre            String    @db.VarChar(200)
  descripcion       String?
  flyer_url         String?
  fecha_evento      DateTime
  estado            String    @default("proximo") @db.VarChar(20)
  id_admin_creador  Int?
  fecha_creacion    DateTime  @default(now())

  admin_creador     Administrador? @relation(fields: [id_admin_creador], references: [id_admin])
  ventas            Venta[]

  galeria           Galeria[]

  @@map("eventos")
}

model Producto {
  id_producto   Int       @id @default(autoincrement())
  nombre        String    @db.VarChar(150)
  precio        Decimal   @db.Decimal(10, 2)
  stock_actual  Int       @default(0)
  disponible    Boolean   @default(true)

  @@map("productos")
}

model Venta {
  id_venta         Int       @id @default(autoincrement())
  id_usuario       Int?
  tipo_venta       String    @db.VarChar(20)
  total            Decimal   @db.Decimal(10, 2)
  estado_pago      String    @default("pendiente") @db.VarChar(20)
  fecha_venta      DateTime  @default(now())
  id_evento        Int?

  usuario          Usuario?  @relation(fields: [id_usuario], references: [id_usuario])
  evento           Evento?   @relation(fields: [id_evento], references: [id_evento])

  @@map("ventas")
}

model Galeria {
  id_media           Int       @id @default(autoincrement())
  id_usuario         Int
  id_evento          Int?
  tipo               String    @db.VarChar(10)
  url                String
  thumbnail_url      String?
  descripcion        String?
  fecha_subida       DateTime  @default(now())
  estado_moderacion  String    @default("aprobado") @db.VarChar(20)
  visible            Boolean   @default(true)
  likes_count        Int       @default(0)

  usuario            Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  evento             Evento?   @relation(fields: [id_evento], references: [id_evento])
  likes              LikeGaleria[]

  @@map("galeria")
}

model LikeGaleria {
  id_like      Int       @id @default(autoincrement())
  id_media     Int
  id_usuario   Int
  fecha        DateTime  @default(now())

  media        Galeria   @relation(fields: [id_media], references: [id_media], onDelete: Cascade)
  usuario      Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@unique([id_media, id_usuario])
  @@map("likes_galeria")
}

model Dinamica {
  id_dinamica       Int       @id @default(autoincrement())
  nombre            String    @db.VarChar(150)
  descripcion       String?
  tipo              String?   @db.VarChar(50)
  reglas            String?
  imagen_url        String?
  fecha_inicio      DateTime?
  fecha_fin         DateTime?
  estado            String    @default("programada") @db.VarChar(20)
  premio            String?

  participaciones   Participacion[]

  @@map("dinamicas")
}

model Participacion {
  id_participacion    Int       @id @default(autoincrement())
  id_dinamica         Int
  id_usuario          Int
  puntaje             Int       @default(0)
  fecha_participacion DateTime  @default(now())

  dinamica            Dinamica  @relation(fields: [id_dinamica], references: [id_dinamica], onDelete: Cascade)
  usuario             Usuario   @relation(fields: [id_usuario], references: [id_usuario])

  @@unique([id_dinamica, id_usuario])
  @@map("participaciones")
}