// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USUARIOS ====================
model Usuario {
  id                Int       @id @default(autoincrement())
  telefono          String    @unique
  nombre            String
  pin_hash          String
  verificado        Boolean   @default(false)
  codigo_sms        String?
  codigo_expira     DateTime?
  avatar_url        String?
  fecha_registro    DateTime  @default(now())
  ultima_conexion   DateTime?

  red_social        RedSocial?
  galerias          Galeria[]
  likes             LikeGaleria[]
  participaciones   Participacion[]
  ventas            Venta[]

  @@map("usuarios")
}

model RedSocial {
  id           Int      @id @default(autoincrement())
  usuario_id   Int      @unique
  bio          String?
  intereses    String?
  instagram    String?
  fecha_update DateTime @default(now())

  usuario      Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@map("red_social")
}

// ==================== ADMINISTRADORES ====================
model Administrador {
  id             Int      @id @default(autoincrement())
  telefono       String   @unique
  nombre         String
  pin_hash       String
  rol            String   // SUPER_ADMIN, CAJA, PUERTA
  activo         Boolean  @default(true)
  fecha_registro DateTime @default(now())

  ventas_atendidas Venta[] @relation("AdminAtiende")

  @@map("administradores")
}

// ==================== EVENTOS ====================
model Evento {
  id            Int      @id @default(autoincrement())
  nombre        String
  descripcion   String?
  fecha         DateTime
  precio        Float      // Precio de entrada base en CLP
  imagen_url    String?
  estado        String   @default("activo") // ACTIVO, CERRADO, CANCELADO
  aforo_maximo  Int?
  fecha_cierre  DateTime?
  fecha_creacion DateTime @default(now())

  ventas        Venta[]
  dinamicas     Dinamica[]
  galerias      Galeria[]

  @@map("eventos")
}

// ==================== PRODUCTOS ====================
model Producto {
  id             Int      @id @default(autoincrement())
  nombre         String
  descripcion    String?
  precio         Float      // Precio en CLP
  stock          Int      @default(0)
  disponible     Boolean  @default(true)
  imagen_url     String?
  fecha_creacion DateTime @default(now())

  detalles       DetalleVenta[]

  @@map("productos")
}

// ==================== VENTAS ====================
model Venta {
  id            Int      @id @default(autoincrement())
  usuario_id    Int
  evento_id     Int      // OBLIGATORIO
  admin_id      Int?
  tipo_venta    String   // "ENTRADA" | "BEBIDA"
  estado        String   // "pendiente" | "pagado" | "preparando" | "listo" | "entregado" | "cancelado"
  total         Decimal  @db.Decimal(10, 2)
  metodo_pago   String?
  notas         String?
  qr_code       String?  @unique          // ← NUEVO
  qr_escaneado  Boolean  @default(false)  // ← NUEVO
  fecha         DateTime @default(now())
  fecha_entrega DateTime?

  usuario  Usuario        @relation(fields: [usuario_id], references: [id])
  evento   Evento         @relation(fields: [evento_id], references: [id])
  admin    Administrador? @relation("AdminAtiende", fields: [admin_id], references: [id])
  detalles DetalleVenta[]

  @@index([evento_id])
  @@index([usuario_id])
  @@index([estado])
}

model DetalleVenta {
  id              Int      @id @default(autoincrement())
  venta_id        Int
  producto_id     Int?              // ← AHORA OPCIONAL
  nombre_snapshot String            // ← NUEVO (nombre histórico)
  cantidad        Int
  precio_unitario Decimal  @db.Decimal(10, 2)
  subtotal        Decimal  @db.Decimal(10, 2)
  estado          String   @default("pendiente")
  notas           String?

  venta    Venta     @relation(fields: [venta_id], references: [id], onDelete: Cascade)
  producto Producto? @relation(fields: [producto_id], references: [id])

  @@index([venta_id])
  @@index([producto_id])
}

// ==================== GALERIA ====================
model Galeria {
  id            Int      @id @default(autoincrement())
  usuario_id    Int
  evento_id     Int?
  imagen_url    String
  descripcion   String?
  aprobado      Boolean  @default(true)
  fecha         DateTime @default(now())

  usuario       Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  evento        Evento?  @relation(fields: [evento_id], references: [id])
  likes         LikeGaleria[]

  @@map("galerias")
}

model LikeGaleria {
  id          Int      @id @default(autoincrement())
  usuario_id  Int
  galeria_id  Int
  fecha       DateTime @default(now())

  usuario     Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  galeria     Galeria  @relation(fields: [galeria_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, galeria_id])
  @@map("likes_galeria")
}

// ==================== DINAMICAS ====================
model Dinamica {
  id            Int      @id @default(autoincrement())
  evento_id     Int
  tipo          String   // TRIVIA, VOTACION, SORTEO, RETO
  titulo        String
  descripcion   String?
  activa        Boolean  @default(true)
  fecha_inicio  DateTime @default(now())
  fecha_fin     DateTime?
  configuracion Json?    // Opciones de la dinámica (preguntas, opciones, etc)

  evento        Evento   @relation(fields: [evento_id], references: [id], onDelete: Cascade)
  participaciones Participacion[]

  @@map("dinamicas")
}

model Participacion {
  id           Int      @id @default(autoincrement())
  usuario_id   Int
  dinamica_id  Int
  respuesta    Json?
  puntos       Int      @default(0)
  fecha        DateTime @default(now())

  usuario      Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  dinamica     Dinamica @relation(fields: [dinamica_id], references: [id], onDelete: Cascade)

  @@map("participaciones")
}